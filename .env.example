# CAgent AI Provider API Keys
# Copy this file to .env and fill in your real keys:
#   cp .env.example .env
#
# Then either:
#   1. source .env && ./mvnw -pl bootstrap spring-boot:run
#   2. ./scripts/start-ragent-local.sh  (auto-loads .env)

BAILIAN_API_KEY=your-bailian-api-key-here
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
